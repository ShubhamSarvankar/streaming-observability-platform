# Kafka
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_TOPIC=access-logs
KAFKA_PARTITIONS=3

# Producer
DATASET_PATH=/data/access_log
REPLAY_RATE_PER_SEC=200

# Spark
WINDOW_MINUTES=10
WATERMARK_MINUTES=5
CHECKPOINT_DIR=/checkpoints
ANOMALY_IP_FLOOR=500
ANOMALY_STATUS_FLOOR=200

# Cassandra
CASSANDRA_CONTACT_POINTS=cassandra
CASSANDRA_PORT=9042
CASSANDRA_LOCAL_DC=datacenter1
CASSANDRA_KEYSPACE=obs

# API
API_PORT=8080

# Agent
API_BASE_URL=http://springboot-api:8080

# LLM provider: "anthropic" (default) or "ollama" (free/offline)
LLM_PROVIDER=anthropic

# Anthropic: LLM_MODEL=claude-haiku-4-5  (requires LLM_API_KEY)
# Ollama:    LLM_MODEL=qwen2.5:7b        (no key needed; pull model first)
LLM_MODEL=claude-haiku-4-5

LLM_API_KEY=                      # set locally, never commit; unused for ollama

# Ollama host -- only used when LLM_PROVIDER=ollama
# Containerised Ollama (profile ollama): http://ollama:11434  <-- default
# Host Ollama fallback:                  http://host.docker.internal:11434
OLLAMA_HOST=http://ollama:11434